# Runtime
NODE_ENV=development
PORT=3000

# Security (required)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=86400

# CORS (required in production)
# Comma-separated list, e.g.
# CORS_ORIGINS=http://localhost:5173,https://municipio.example.com
CORS_ORIGINS=http://localhost:5173

# Database (prefer DATABASE_URL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/muni_digital

# Legacy fallback DB vars (only if DATABASE_URL is not used)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=muni_digital

# Admin seed (recommended off in production)
SEED_ADMIN_ON_BOOT=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_DNI=12345678
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=Sistema
ADMIN_BIRTHDATE=1990-01-01
ADMIN_COUNTRY=AR
ADMIN_PROVINCE=Buenos Aires
ADMIN_CITY=Roque Pérez
